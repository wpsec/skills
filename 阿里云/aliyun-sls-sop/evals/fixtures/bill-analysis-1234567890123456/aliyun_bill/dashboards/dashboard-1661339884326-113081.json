            "logstore": "aliyun_bill",
            "name": "A",
            "project": "bill-analysis-1234567890123456",
            "query": "(\n  *\n  and source :instance_bill\n  and ProductCode :SLS\n) |\nwith t1 as (\n    select\n      Region,\n\t  Project,\n\t  Logstore,\n      InstanceID,\n      concat(BillingItem, ' (', Unit, ')') BillingItem,\n      Usage\n    from(\n        select\n          split_part(InstanceID, ';', 4) as Region,\n\t\t  split_part(InstanceID, ';', 2) as Project,\n          InstanceID,\n          split_part(InstanceID, ';', 3) as Logstore,\n          BillingItem,\n          arbitrary(UsageUnit) as Unit,\n          sum(Usage) as Usage\n        FROM          log\n\t\twhere  split_part(InstanceID, ';', 3)!='k8s-event' and split_part(InstanceID, ';', 4)!='cn-huhehaote' and split_part(InstanceID, ';', 3) like '%%' and split_part(InstanceID, ';', 2) like '%%' and split_part(InstanceID, ';', 4) like '%%'\n        group by\n          InstanceID,\n          UsageUnit,\n          BillingItem\n      )\n)\n, t2 as (\n    select\n        InstanceID,\n        round(di [1], 3) as \"费用\",\n        round(di[2], 3) as \"前日费用\",\n        round(di [3] * 100 -100, 3) \"同比前日\"\n    from(\n        select\n            InstanceID,\n            compare(cost, 2592000) as di\n        from (\n            select\n                InstanceID,\n                round(sum(PretaxAmount), 2) as cost\n            FROM              log\n            group by\n              InstanceID\n        )\n        group by\n          InstanceID\n    )\n)\n\nselect \n    t1.Region as Region,\n    t1.Project as Project,\n    t1.Logstore as Logstore,\n    t1.InstanceID as InstanceID,\n    t1.BillingItem as BillingItem,\n    t1.Usage as Usage,\n    t2.\"费用\"  as \"费用 (元)\",\n    t2.\"前日费用\"  as \"前日费用 (元)\",\n    t2.\"同比前日\"as \"同比前日 (%)\"\nfrom t1 left join t2 on t1.InstanceID = t2.InstanceID \nORDER by InstanceID\nlimit 10000",
            "tokenQuery": "(\n  *\n  and source :instance_bill\n  and ProductCode :SLS\n) |\nwith t1 as (\n    select\n      Region,\n\t  Project,\n\t  Logstore,\n      InstanceID,\n      concat(BillingItem, ' (', Unit, ')') BillingItem,\n      Usage\n    from(\n        select\n          split_part(InstanceID, ';', 4) as Region,\n\t\t  split_part(InstanceID, ';', 2) as Project,\n          InstanceID,\n          split_part(InstanceID, ';', 3) as Logstore,\n          BillingItem,\n          arbitrary(UsageUnit) as Unit,\n          sum(Usage) as Usage\n        FROM          log\n\t\twhere  split_part(InstanceID, ';', 3)!='k8s-event' and split_part(InstanceID, ';', 4)!='cn-huhehaote' and split_part(InstanceID, ';', 3) like '${{Logstore|%%}}' and split_part(InstanceID, ';', 2) like '${{Project|%%}}' and split_part(InstanceID, ';', 4) like '${{Region|%%}}'\n        group by\n          InstanceID,\n          UsageUnit,\n          BillingItem\n      )\n)\n, t2 as (\n    select\n        InstanceID,\n        round(di [1], 3) as \"费用\",\n        round(di[2], 3) as \"前日费用\",\n        round(di [3] * 100 -100, 3) \"同比前日\"\n    from(\n        select\n            InstanceID,\n            compare(cost, 2592000) as di\n        from (\n            select\n                InstanceID,\n                round(sum(PretaxAmount), 2) as cost\n            FROM              log\n            group by\n              InstanceID\n        )\n        group by\n          InstanceID\n    )\n)\n\nselect \n    t1.Region as Region,\n    t1.Project as Project,\n    t1.Logstore as Logstore,\n    t1.InstanceID as InstanceID,\n    t1.BillingItem as BillingItem,\n    t1.Usage as Usage,\n    t2.\"费用\"  as \"费用 (元)\",\n    t2.\"前日费用\"  as \"前日费用 (元)\",\n    t2.\"同比前日\"as \"同比前日 (%)\"\nfrom t1 left join t2 on t1.InstanceID = t2.InstanceID \nORDER by InstanceID\nlimit 10000"
