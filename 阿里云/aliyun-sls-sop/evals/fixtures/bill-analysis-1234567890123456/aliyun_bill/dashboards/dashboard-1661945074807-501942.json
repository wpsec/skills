            "name": "A",
            "project": "bill-analysis-1234567890123456",
            "query": "(\n  *\n  and source :instance_bill\n  and ProductCode :oss\n) |\nwith t1 as (\n    select\n      Region,\n      InstanceID,\n      InstanceType,\n      concat(BillingItem, ' (', Unit, ')') as BillingItem,\n      Usage\n    from(\n        select\n          split_part(InstanceID, ';', 1) as Region,\n          InstanceID,\n          COALESCE(split_part(InstanceID, ';', 3), split_part(InstanceID, ';', 2)) as InstanceType,\n          BillingItem,\n          arbitrary(UsageUnit) as Unit,\n          sum(Usage) as Usage\n        FROM          log\n\t\twhere InstanceID like '%%' and Region like '%%' \n        group by\n          InstanceID,\n          UsageUnit,\n          BillingItem\n      )\n)\n, t2 as (\n    select\n        InstanceID,\n        round(di [1], 3) as \"费用\",\n        round(di[2], 3) as \"前日费用\",\n        round(di [3] * 100 -100, 3) \"同比前日\"\n    from(\n        select\n            InstanceID,\n            compare(cost, 2592000) as di\n        from (\n            select\n                InstanceID,\n                round(sum(PretaxAmount), 2) as cost\n            FROM              log\n            group by\n              InstanceID\n        )\n        group by\n          InstanceID\n    )\n)\n\nselect \n    t1.Region as region,\n    t1.InstanceID as InstanceID,\n    t1.InstanceType as InstanceType,\n    t1.BillingItem as BillingItem,\n    t1.Usage as Usage,\n    t2.\"费用\"  as \"费用 (元)\",\n    t2.\"前日费用\"  as \"前日费用 (元)\",\n    t2.\"同比前日\"as \"同比前日 (%)\"\nfrom t1 Left join t2 on t1.InstanceID = t2.InstanceID\nlimit 10000",
            "tokenQuery": "(\n  *\n  and source :instance_bill\n  and ProductCode :oss\n) |\nwith t1 as (\n    select\n      Region,\n      InstanceID,\n      InstanceType,\n      concat(BillingItem, ' (', Unit, ')') as BillingItem,\n      Usage\n    from(\n        select\n          split_part(InstanceID, ';', 1) as Region,\n          InstanceID,\n          COALESCE(split_part(InstanceID, ';', 3), split_part(InstanceID, ';', 2)) as InstanceType,\n          BillingItem,\n          arbitrary(UsageUnit) as Unit,\n          sum(Usage) as Usage\n        FROM          log\n\t\twhere InstanceID like '${{InstanceID|%%}}' and Region like '${{Region|%%}}' \n        group by\n          InstanceID,\n          UsageUnit,\n          BillingItem\n      )\n)\n, t2 as (\n    select\n        InstanceID,\n        round(di [1], 3) as \"费用\",\n        round(di[2], 3) as \"前日费用\",\n        round(di [3] * 100 -100, 3) \"同比前日\"\n    from(\n        select\n            InstanceID,\n            compare(cost, 2592000) as di\n        from (\n            select\n                InstanceID,\n                round(sum(PretaxAmount), 2) as cost\n            FROM              log\n            group by\n              InstanceID\n        )\n        group by\n          InstanceID\n    )\n)\n\nselect \n    t1.Region as region,\n    t1.InstanceID as InstanceID,\n    t1.InstanceType as InstanceType,\n    t1.BillingItem as BillingItem,\n    t1.Usage as Usage,\n    t2.\"费用\"  as \"费用 (元)\",\n    t2.\"前日费用\"  as \"前日费用 (元)\",\n    t2.\"同比前日\"as \"同比前日 (%)\"\nfrom t1 Left join t2 on t1.InstanceID = t2.InstanceID\nlimit 10000"
