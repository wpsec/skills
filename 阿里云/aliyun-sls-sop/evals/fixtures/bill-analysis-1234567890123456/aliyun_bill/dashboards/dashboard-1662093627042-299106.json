            "logstore": "aliyun_bill",
            "name": "A",
            "project": "bill-analysis-1234567890123456",
            "query": "(\n  source: instance_bill\n  and ecs\n) |\nselect\n  Region,\n  round(sum(PostPaid), 0) as \"按量付费\",\n  round(sum(PrePaid), 0) as \"包年包月\",\n  round(sum(PostPaid + PrePaid), 0) as \"总计\"\nFROM  (\n    select\n      Region,\n      if(ProductDetail = '云服务器ECS-按量付费', PaymentAmount, 0) as PostPaid,\n      if(\n        ProductDetail != '云服务器ECS-按量付费',\n        PaymentAmount,\n        0\n      ) as PrePaid\n    FROM      log\n  )\ngroup by\n  region\norder by\n  \"总计\" desc\nlimit\n  1000",
            "tokenQuery": "(\n  source: instance_bill\n  and ecs\n) |\nselect\n  Region,\n  round(sum(PostPaid), 0) as \"按量付费\",\n  round(sum(PrePaid), 0) as \"包年包月\",\n  round(sum(PostPaid + PrePaid), 0) as \"总计\"\nFROM  (\n    select\n      Region,\n      if(ProductDetail = '云服务器ECS-按量付费', PaymentAmount, 0) as PostPaid,\n      if(\n        ProductDetail != '云服务器ECS-按量付费',\n        PaymentAmount,\n        0\n      ) as PrePaid\n    FROM      log\n  )\ngroup by\n  region\norder by\n  \"总计\" desc\nlimit\n  1000"
