            "logstore": "aliyun_bill",
            "name": "A",
            "project": "bill-analysis-1234567890123456",
            "query": "source: instance_bill\nand ecs |\nselect\n  region,\n  regexp_extract(tag, 'value:(\\w{32})', 1) as k8s,\n  round(sum(PretaxAmount), 0) as pay\nfrom(\n    select\n      region,\n      regexp_extract_all(tag, 'key:(\\S+)\\s+value:([^\\s;]+)') as arr,\n      PretaxAmount\n    FROM      log\n  ),\n  unnest(arr) as t(tag)\nwhere\n  tag like 'key:ack.aliyun.com%'\ngroup by\n  region,\n  k8s\norder by\n  pay desc\nlimit\n  1000",
            "tokenQuery": "source: instance_bill\nand ecs |\nselect\n  region,\n  regexp_extract(tag, 'value:(\\w{32})', 1) as k8s,\n  round(sum(PretaxAmount), 0) as pay\nfrom(\n    select\n      region,\n      regexp_extract_all(tag, 'key:(\\S+)\\s+value:([^\\s;]+)') as arr,\n      PretaxAmount\n    FROM      log\n  ),\n  unnest(arr) as t(tag)\nwhere\n  tag like 'key:ack.aliyun.com%'\ngroup by\n  region,\n  k8s\norder by\n  pay desc\nlimit\n  1000"
          }
